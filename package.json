{
  "name": "chess-review-mate",
  "version": "1.0.0",
  "description": "Chrome extension for structured chess game review on Lichess Study",
  "private": true,
  "scripts": {
    "build": "esbuild src/content.ts --bundle --outfile=dist/content.js --format=iife --target=es2020 && cp src/styles.css dist/styles.css",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "fast-check": "^4.1.1",
    "jsdom": "^29.0.1",
    "typescript": "^5.7.0",
    "vitest": "^3.2.1"
  }
}
